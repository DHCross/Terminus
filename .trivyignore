# Trivy Ignore File
# This file configures Trivy security scanner to skip specific files and directories
# that are not part of the production deployment or contain development-only dependencies.

# Build outputs
out/**
dist/**

# Development and test dependencies
node_modules/**
.vscode-test/**
test/**
coverage/**
.nyc_output/**

# Version control and editor files
.git/**
.vscode/**

# Documentation and assets
docs/**
plan/**
spec/**
assets/**
media/**

# Configuration files (not runtime dependencies)
*.config.js
*.config.ts
webpack.config.js
tsconfig*.json
.mocharc.json
.nycrc.json
